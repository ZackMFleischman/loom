{
  "name": "loom",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @loom/engine-app dev",
    "sidecar": "pnpm --filter @loom/sidecar dev",
    "typecheck": "node scripts/build-catalog.mjs && tsc --noEmit -p .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "catalog": "node scripts/build-catalog.mjs",
    "pack:add": "node scripts/pack.mjs add",
    "pack:update": "node scripts/pack.mjs update",
    "test": "pnpm -r --if-present test && pnpm test:content && pnpm test:scripts",
    "test:content": "vitest run --config vitest.config.ts",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "validate": "pnpm validate:m0 && pnpm validate:m1 && pnpm validate:m2 && pnpm validate:m3 && pnpm validate:m4 && pnpm validate:m5 && pnpm validate:m6 && pnpm validate:layers && pnpm validate:projects && pnpm validate:m9 && pnpm validate:fixtures && pnpm validate:m7 && pnpm validate:m8 && pnpm validate:m11 && pnpm validate:modulators && pnpm validate:panic && pnpm validate:stdlib",
    "validate:m0": "node scripts/validate-m0.mjs",
    "validate:m1": "node scripts/validate-m1.mjs",
    "validate:m2": "node scripts/validate-m2.mjs",
    "validate:m3": "node scripts/validate-m3.mjs",
    "validate:m4": "node scripts/validate-m4.mjs",
    "validate:m5": "node scripts/validate-m5.mjs",
    "validate:m6": "node scripts/validate-m6.mjs",
    "validate:layers": "node scripts/validate-layers.mjs",
    "validate:projects": "node scripts/validate-projects.mjs",
    "validate:m9": "node scripts/validate-m9.mjs",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "validate:m7": "node scripts/validate-m7.mjs",
    "validate:m8": "node scripts/validate-m8.mjs",
    "validate:m11": "node scripts/validate-m11.mjs",
    "validate:modulators": "node scripts/validate-modulators.mjs",
    "validate:panic": "node scripts/validate-panic.mjs",
    "validate:stdlib": "node scripts/validate-stdlib.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@types/node": "25.9.2",
    "@types/three": "0.184.1",
    "happy-dom": "^20.10.2",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "three": "0.184.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.6.0"
}
