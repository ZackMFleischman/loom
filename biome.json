{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/*/src/**/*.{ts,tsx}",
      "packages/*/test/**/*.{ts,tsx}",
      "content/**/*.ts",
      "scripts/**/*.mjs",
      "!content/CATALOG.md",
      "!content/state",
      "!content/assets",
      "!**/artifacts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off",
        "useTemplate": "off",
        "useExponentiationOperator": "off"
      },
      "suspicious": {
        "noApproximativeNumericConstant": "off",
        "noImplicitAnyLet": "warn",
        "useIterableCallbackReturn": "warn",
        "noArrayIndexKey": "warn"
      },
      "complexity": {
        "useSimpleNumberKeys": "off",
        "noUselessContinue": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedFunctionParameters": "warn"
      }
    }
  }
}
